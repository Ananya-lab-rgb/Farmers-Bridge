{
  "name": "LaborerProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to User entity"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "plowing",
          "harvesting",
          "irrigation",
          "pesticide_application",
          "pruning",
          "livestock_care",
          "machinery_operation",
          "seeding",
          "weeding",
          "general_farm_work"
        ]
      },
      "description": "Skills offered by the laborer"
    },
    "hourly_rate": {
      "type": "number",
      "description": "Hourly rate in local currency"
    },
    "experience_years": {
      "type": "number",
      "description": "Years of experience"
    },
    "availability_status": {
      "type": "string",
      "enum": [
        "available",
        "busy",
        "unavailable"
      ],
      "default": "available",
      "description": "Current availability status"
    },
    "available_days": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "monday",
          "tuesday",
          "wednesday",
          "thursday",
          "friday",
          "saturday",
          "sunday"
        ]
      },
      "description": "Days available for work"
    },
    "rating": {
      "type": "number",
      "description": "Average rating out of 5"
    },
    "total_jobs": {
      "type": "number",
      "default": 0,
      "description": "Total completed jobs"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether profile is active"
    }
  },
  "required": [
    "user_id",
    "skills",
    "hourly_rate"
  ]
}